PORT=3000

# Bot de Twitch para escuchar comandos del chat
TWITCH_BOT_USERNAME=tu_bot_twitch
TWITCH_OAUTH=oauth:xxxxxxxxxxxxxxxxxxxxxx
TWITCH_CHANNEL=voranix

# OAuth Twitch para login de streamers/admins
TWITCH_CLIENT_ID=tu_twitch_client_id
TWITCH_CLIENT_SECRET=tu_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:3000/api/auth/twitch/callback

# Admins de la comunidad
ADMIN_TWITCH_LOGINS=tu_login_admin,otro_admin

# Dashboard frontend
DASHBOARD_URL=http://localhost:4200

# Base de datos Postgres
DATABASE_URL=postgresql://usuario:password@host:5432/database

# Produccion
NODE_ENV=development
